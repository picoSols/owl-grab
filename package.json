{
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/benchmarks/next-app"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build --filter=owl-grab --filter=@owl-grab/cli --filter=@owl-grab/utils && pnpm --filter grab build",
    "dev": "turbo dev --filter=owl-grab --filter=@owl-grab/cli --filter=@owl-grab/utils",
    "test": "turbo run test --filter=owl-grab --filter=@owl-grab/cli",
    "typecheck": "pnpm --filter owl-grab typecheck",
    "lint": "pnpm --filter owl-grab lint",
    "lint:fix": "pnpm --filter owl-grab lint:fix",
    "format": "oxfmt",
    "extension:dev": "pnpm --filter web-extension dev",
    "extension:build": "pnpm --filter web-extension build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "oxfmt": "^0.27.0",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "untun": "^0.1.3"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@10.24.0"
}